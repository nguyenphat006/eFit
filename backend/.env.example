# ─── DATABASE ──────────────────────────────────────────────────────────────
# Neon (or any Postgres) connection string.
# IMPORTANT for Neon:
#   1. Replace scheme: postgresql://  →  postgresql+asyncpg://
#   2. Replace query: ?sslmode=require →  ?ssl=require
#   (asyncpg uses `ssl`, not `sslmode`)
#
# Example after conversion:
# DATABASE_URL=postgresql+asyncpg://neondb_owner:abc123@ep-cool-name-12345.us-east-2.aws.neon.tech/neondb?ssl=require
DATABASE_URL=

# Toggle SQL query logging — true only for debug (leaks data into logs)
DB_ECHO=false

# ─── APP ENV ───────────────────────────────────────────────────────────────
ENV=development

# ─── SECURITY ──────────────────────────────────────────────────────────────
# In production (ENV=production) this MUST be set, otherwise app fails to start.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# ─── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── FILE UPLOAD ───────────────────────────────────────────────────────────
BASE_URL=http://localhost:8000

# ─── AI (optional — chỉ cần khi muốn dùng tính năng AI Coach) ──────────────
GEMINI_API_KEY=
OPENAI_API_KEY=
